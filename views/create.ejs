 <!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Event</title>

    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/create.css">
</head>

<body>

    <nav>
        <h1> Admin Console</h1>
        <a href="/" class="btn-nav">Back to Home</a>
    </nav>

    <div class="container">
        <div class="form-wrapper">
            <div class="form-header">
                <h1>Add New Event</h1>
                <p style="color: #777; margin: 5px 0 0;">Create a new experience for students</p> 
            </div>

            <form action="/admin/create" method="POST" enctype="multipart/form-data">

                <div class="form-group">
                    <label for="name">Event Name</label>
                    <input type="text" id="name" name="name" placeholder="e.g. Diwali Mela 2025" required>
                </div>

                <div class="form-group">
                    <label for="image">Event Poster (Image)</label>
                    <input type="file" id="image" name="image" accept="image/*" class="file-input-custom"> 
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label for="date">Date</label>
                        <input type="date" id="date" name="date" required>
                    </div>

                    <div class="form-group">
                        <label for="venue">Venue</label>
                        <input type="text" id="venue" name="venue" placeholder="e.g. Auditorium 1" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="4"
                        placeholder="Describe the event details..."></textarea>
                </div>

                <button type="submit" class="btn-block">Save Event</button>
            </form>
            <a href="/" class="back-link">Cancel and go back</a>
        </div>
    </div>

</body>

</html>