<header class="main-header">
    <nav class="navbar">
        <div class="logo">
            <a href="/">EventUs 🏛️</a>
        </div>
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            
            <% if (typeof user !== 'undefined' && user) { %>
                <li><a href="/dashboard">Dashboard</a></li>
                
                <% if (user.role === 'admin') { %>
                    <li><a href="/admin/create" class="btn btn-admin">Create Event</a></li>
                <% } %>
                
                <li><a href="/logout" class="btn btn-logout">Logout</a></li>
            <% } else { %>
                <li><a href="/login" class="btn btn-login">Login</a></li>
                <li><a href="/register" class="btn btn-register">Register</a></li>
            <% } %>
        </ul>
    </nav>
</header>

<style>
    .main-header {
        background-color: #004d99; /* Deep College Blue */
        padding: 10px 0;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
        margin-bottom: 20px; /* Space below header */
    }
    .navbar {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 20px;
    }
    .logo a {
        color: white;
        font-size: 1.6em;
        font-weight: 700;
        text-decoration: none;
    }
    .nav-links {
        list-style: none;
        display: flex;
        gap: 15px;
        margin: 0;
        padding: 0;
    }
    .nav-links li {
        margin: 0;
    }
    .nav-links a {
        color: white;
        text-decoration: none;
        padding: 8px 12px;
        border-radius: 5px;
        transition: background-color 0.3s;
        font-weight: 500;
    }
    .nav-links a:hover {
        background-color: #003366;
    }
    
    /* Button styles for emphasis */
    .btn-admin {
        background-color: #ffc107; /* Amber for admin actions */
        color: #333;
    }
    .btn-admin:hover {
        background-color: #e0a800;
    }
    .btn-logout {
        background-color: #dc3545; /* Red for logout */
    }
    .btn-logout:hover {
        background-color: #c82333;
    }
    .btn-login, .btn-register {
        background-color: #28a745; /* Green for signup/login */
    }
    .btn-login:hover, .btn-register:hover {
        background-color: #1e7e34;
    }
</style>