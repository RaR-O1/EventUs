 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Event - EventUs</title>
    
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/create.css"> </head>
<body>

    <nav>
        <a href="/" class="brand-wrapper">
            <img src="/images/logo.png" alt="EventUs Logo" class="nav-logo"> 
            <h1>EVENTUS</h1>
        </a>
        <a href="/" class="btn-nav">Back to Home</a>
    </nav>

    <div class="container">
        <div class="form-wrapper">
            <div class="form-header">
                <h1>Edit Event</h1>
                <p style="color: #888; margin: 5px 0 0;">Update details for <strong><%= event.name %></strong></p>
            </div>

            <form action="/edit/<%= event.id %>" method="POST" enctype="multipart/form-data">
                
                <input type="hidden" name="old_image" value="<%= event.image %>">

                <div class="form-group">
                    <label>Current Event Image</label>
                    <% if (event.image && event.image !== 'default.jpg') { %>
                        <img src="/uploads/<%= event.image %>" alt="Event Image" style="width: 100%; max-width: 300px; height: auto; border-radius: 8px; border: 1px solid #444; margin-bottom: 10px;">
                    <% } else { %>
                        <div style="padding: 20px; background: #333; color: #888; text-align: center; border-radius: 8px; margin-bottom: 10px;">
                            No image uploaded yet
                        </div>
                    <% } %>
                    
                    <label for="image">Upload New Image (Optional)</label>
                    <input type="file" id="image" name="image" accept="image/*">
                    <small style="color: #666; display: block; margin-top: 5px;">Leave blank to keep the current image.</small>
                </div>

                <div class="form-group">
                    <label for="name">Event Name</label>
                    <input type="text" id="name" name="name" value="<%= event.name %>" required>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label for="date">Date</label>
                        <% 
                           let dateObj = new Date(event.date);
                           // Fix timezone issue for date picker
                           dateObj.setMinutes(dateObj.getMinutes() - dateObj.getTimezoneOffset());
                           let dateStr = dateObj.toISOString().split('T')[0];
                        %>
                        <input type="date" id="date" name="date" value="<%= dateStr %>" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="venue">Venue</label>
                        <input type="text" id="venue" name="venue" value="<%= event.venue %>" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="4"><%= event.description %></textarea>
                </div>

                <button type="submit" class="btn-block">Update Event</button>
            </form>

            <a href="/" class="back-link">Cancel changes</a>
        </div>
    </div>

</body>
</html>